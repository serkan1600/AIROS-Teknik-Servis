@model List<AIROSWEB.DAL.Db.TblMesajlar>
@{
    ViewBag.Title = ViewBag.Title ?? "Mesajlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <i class="fas fa-envelope fa-3x text-primary mb-3"></i>
                <h3 class="fw-bold">@ViewBag.ToplamSayisi</h3>
                <p class="text-muted mb-0">Toplam Mesaj</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <i class="fas fa-envelope-open fa-3x text-warning mb-3"></i>
                <h3 class="fw-bold">@ViewBag.OkunmamisSayisi</h3>
                <p class="text-muted mb-0">Okunmamış</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <i class="fas fa-reply fa-3x text-danger mb-3"></i>
                <h3 class="fw-bold">@ViewBag.YanitlanmamisSayisi</h3>
                <p class="text-muted mb-0">Yanıtlanmamış</p>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="fas fa-inbox"></i> @ViewBag.Title</h4>
        <div class="btn-group">
            <a href="@Url.Action("Index", new { durum = "tumu" })" class="btn btn-sm @(Request.QueryString["durum"] == "tumu" || string.IsNullOrEmpty(Request.QueryString["durum"]) ? "btn-light" : "btn-outline-light")">
                Tümü
            </a>
            <a href="@Url.Action("Index", new { durum = "okunmamis" })" class="btn btn-sm @(Request.QueryString["durum"] == "okunmamis" ? "btn-light" : "btn-outline-light")">
                Okunmamış
            </a>
            <a href="@Url.Action("Index", new { durum = "yanitlanmamis" })" class="btn btn-sm @(Request.QueryString["durum"] == "yanitlanmamis" ? "btn-light" : "btn-outline-light")">
                Yanıtlanmamış
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="40"></th>
                            <th>Gönderen</th>
                            <th>Konu</th>
                            <th>Mesaj</th>
                            <th>Tarih</th>
                            <th>Durum</th>
                            <th width="100">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(!item.Okundu ? "table-warning" : "")">
                                <td class="text-center">
                                    @if (!item.Okundu)
                                    {
                                        <i class="fas fa-circle text-warning" title="Okunmadı"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-circle text-muted" title="Okundu"></i>
                                    }
                                </td>
                                <td>
                                    <strong>@item.AdSoyad</strong><br />
                                    <small class="text-muted">
                                        @if (!string.IsNullOrEmpty(item.Email))
                                        {
                                            <i class="fas fa-envelope"></i> @item.Email<br />
                                        }
                                        @if (!string.IsNullOrEmpty(item.Telefon))
                                        {
                                            <i class="fas fa-phone"></i> @item.Telefon
                                        }
                                    </small>
                                </td>
                                <td>@(item.Konu ?? "-")</td>
                                <td>
                                    @{
                                        var mesajOnizleme = item.Mesaj.Length > 100 ? item.Mesaj.Substring(0, 100) + "..." : item.Mesaj;
                                    }
                                    @mesajOnizleme
                                </td>
                                <td>
                                    <small>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</small>
                                </td>
                                <td>
                                    @if (item.Yanitlandi)
                                    {
                                        <span class="badge bg-success">Yanıtlandı</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Bekliyor</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-primary" title="Detay">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @using (Html.BeginForm("Delete", "Mesajlar", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Bu mesajı silmek istediğinize emin misiniz?');" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-5 text-center text-muted">
                <i class="fas fa-inbox fa-4x mb-3"></i>
                <p class="mb-0">Henüz mesaj bulunmuyor.</p>
            </div>
        }
    </div>
</div>
