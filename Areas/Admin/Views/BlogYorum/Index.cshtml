@model List<AIROSWEB.DAL.Db.TblBlogYorum>
@{
    ViewBag.Title = "Blog Yorumları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-info text-white">
        <h4 class="mb-0"><i class="fas fa-comments"></i> Blog Yorumları</h4>
    </div>
    <div class="card-body">
        <table class="table table-hover table-bordered">
            <thead class="table-light">
                <tr>
                    <th width="50">#</th>
                    <th>Ad Soyad</th>
                    <th>Email</th>
                    <th>Blog Yazısı</th>
                    <th>Yorum</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th width="120">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.AdSoyad</td>
                        <td>@item.Email</td>
                        <td>
                            @if(item.Blog != null) {
                                <a href="/Blog/Detay/@item.BlogId" target="_blank">@item.Blog.Baslik</a>
                            } else {
                                <span class="text-muted">Silinmiş Yazı</span>
                            }
                        </td>
                        <td>@(item.Yorum.Length > 50 ? item.Yorum.Substring(0, 50) + "..." : item.Yorum)</td>
                        <td>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @using (Html.BeginForm("Onayla", "BlogYorum", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(item.OnayliMi ? "btn-success" : "btn-outline-secondary")">
                                    @(item.OnayliMi ? "Onaylı" : "Bekliyor")
                                </button>
                            }
                        </td>
                        <td>
                            <div class="btn-group">
                                <a href="@Url.Action("Cevapla", "BlogYorum", new { id = item.Id })" class="btn btn-primary btn-sm" title="Cevapla">
                                    <i class="fas fa-reply"></i>
                                    @if(!string.IsNullOrEmpty(item.YoneticiCevabi)) { <i class="fas fa-check-double ms-1 small"></i> }
                                </a>
                                @using (Html.BeginForm("Delete", "BlogYorum", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Bu yorumu silmek istediğinize emin misiniz?');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm border-start-0 rounded-start-0"><i class="fas fa-trash"></i></button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
