@model List<AIROSWEB.DAL.Db.TblRandevular>
@{
    ViewBag.Title = "Randevu Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0 text-gray-800"><i class="fas fa-calendar-check text-primary me-2"></i> Randevu Yönetimi</h2>
    <div class="btn-group">
        <a href="@Url.Action("Index", new { durum = "" })" class="btn btn-outline-secondary btn-sm @(Request.QueryString["durum"] == "" ? "active" : "")">Tümü</a>
        <a href="@Url.Action("Index", new { durum = "Beklemede" })" class="btn btn-outline-warning btn-sm @(Request.QueryString["durum"] == "Beklemede" ? "active" : "")">Bekleyenler</a>
        <a href="@Url.Action("Index", new { durum = "Onaylandı" })" class="btn btn-outline-success btn-sm @(Request.QueryString["durum"] == "Onaylandı" ? "active" : "")">Onaylananlar</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Müşteri</th>
                        <th>Hizmet</th>
                        <th>Randevu Tarihi</th>
                        <th>Saat</th>
                        <th>Durum</th>
                        <th>Kayıt Tarihi</th>
                        <th width="120">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.AdSoyad</strong><br />
                                <small class="text-muted"><i class="fas fa-phone fa-xs"></i> @item.Telefon</small>
                            </td>
                            <td><span class="badge bg-info text-dark">@item.HizmetAdi</span></td>
                            <td>@(item.RandevuTarihi.HasValue ? item.RandevuTarihi.Value.ToString("dd.MM.yyyy") : "-")</td>
                            <td>@item.RandevuSaati</td>
                            <td>
                                @if (item.Durum == "Beklemede")
                                {
                                    <span class="badge bg-warning text-dark"><i class="fas fa-clock"></i> Beklemede</span>
                                }
                                else if (item.Durum == "Onaylandı")
                                {
                                    <span class="badge bg-success"><i class="fas fa-check"></i> Onaylandı</span>
                                }
                                else if (item.Durum == "Tamamlandı")
                                {
                                    <span class="badge bg-primary"><i class="fas fa-flag-checkered"></i> Tamamlandı</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="fas fa-times"></i> @item.Durum</span>
                                }
                            </td>
                            <td><small>@item.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</small></td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-primary" title="Detay">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @{
                                        var tarihStr = item.RandevuTarihi.HasValue ? item.RandevuTarihi.Value.ToString("dd.MM.yyyy") : "en kısa sürede";
                                        var wpMesaj = $"Merhaba {item.AdSoyad}, Airos Teknik Servis randevunuz ({tarihStr} - {item.HizmetAdi}) hakkında bilgi için iletişime geçiyoruz.";
                                        var wpLink = $"https://wa.me/90{item.Telefon.Replace(" ", "").TrimStart('0')}?text={Uri.EscapeDataString(wpMesaj)}";
                                    }
                                    <a href="@wpLink" target="_blank" class="btn btn-success" title="WhatsApp Bildirimi">
                                        <i class="fab fa-whatsapp"></i>
                                    </a>
                                    <button type="button" class="btn btn-danger" onclick="confirmDelete(@item.Id)" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Kayıtlı randevu bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" action="@Url.Action("Delete")" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Bu randevu kaydını silmek istediğinize emin misiniz?')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}
