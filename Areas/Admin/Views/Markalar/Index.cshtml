@model List<AIROSWEB.DAL.Db.TblMarkalar>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Markalar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0 text-dark">Marka Yönetimi</h3>
        <p class="text-muted small mb-0">Web sitesinde görüntülenen partner markaların listesi.</p>
    </div>
    <a href="@Url.Action("Create", "Markalar")" class="btn btn-primary shadow-sm hover-up">
        <i class="fas fa-plus-circle me-2"></i>Yeni Marka Ekle
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4" style="width: 80px;">Sıra</th>
                        <th style="width: 150px;">Logo</th>
                        <th>Marka Bilgisi</th>
                        <th style="width: 120px;">Durum</th>
                        <th class="text-end pe-4" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr id="row_@item.Id">
                                <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                                <td>
                                    <div class="bg-white p-2 border rounded shadow-sm d-flex align-items-center justify-content-center" style="width: 120px; height: 60px;">
                                        @{
                                            string logoUrl = item.LogoYolu;
                                            if (string.IsNullOrEmpty(logoUrl))
                                            {
                                                logoUrl = $"https://placehold.co/120x60/EEE/666?text={item.MarkaAdi}";
                                            }
                                        }
                                        <img src="@logoUrl" alt="@item.MarkaAdi" style="max-height: 40px; max-width: 100px; object-fit: contain;" onerror="this.src='https://placehold.co/120x60/EEE/666?text=Hata';" />
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold d-block text-dark">@item.MarkaAdi</span>
                                    <small class="text-muted d-block">Eklenme: @(DateTime.Now.ToShortDateString())</small>
                                </td>
                                <td>
                                    @if (item.AktifMi == true)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-3 py-2 rounded-pill">
                                            <i class="fas fa-check-circle me-1"></i>Aktif
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger px-3 py-2 rounded-pill">
                                            <i class="fas fa-times-circle me-1"></i>Pasif
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm border rounded overflow-hidden">
                                        <a href="@Url.Action("Edit", "Markalar", new { id = item.Id })" class="btn btn-white btn-sm px-3" title="Düzenle">
                                            <i class="fas fa-edit text-warning"></i>
                                        </a>
                                        @using (Html.BeginForm("Delete", "Markalar", new { id = item.Id }, FormMethod.Post, new { style="display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-white btn-sm px-3" title="Sil" onclick="return confirm('Bu markayı kalıcı olarak silmek istediğinize emin misiniz?');">
                                                <i class="fas fa-trash text-danger"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-5 text-center text-muted">
                                <i class="fas fa-tags fa-3x mb-3 opacity-25"></i>
                                <p>Henüz herhangi bir marka eklenmemiş.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-success-subtle { background-color: #e6f7e9; }
    .bg-danger-subtle { background-color: #fcecea; }
    .btn-white { background-color: #fff; border: none; }
    .btn-white:hover { background-color: #f8f9fa; }
    .hover-up { transition: all 0.2s; }
    .hover-up:hover { transform: translateY(-2px); }
    .shadow-inner { box-shadow: inset 0 2px 4px 0 rgba(0,0,0,0.06); }
</style>

</script>
