@model AIROSWEB.DAL.Db.TblMarkalar
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Yeni Marka Ekle";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white py-3">
        <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Yeni Marka Ekle</h5>
    </div>
    <div class="card-body p-4">
        @using (Html.BeginForm("Create", "Markalar", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted">Marka Adı</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-tag text-primary"></i></span>
                            @Html.TextBoxFor(x => x.MarkaAdi, new { @class = "form-control border-start-0 ps-0", required = "required", placeholder = "Örn: Arçelik, Vestel..." })
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted">Marka Logosu</label>
                        <div class="input-group mb-2">
                             @Html.TextBoxFor(m => m.LogoYolu, new { @class = "form-control", id = "ResimYolu", placeholder = "/Uploads/logo.png" })
                            <button type="button" class="btn btn-primary" onclick="document.getElementById('fileUpload').click()">
                                <i class="fas fa-upload me-1"></i> Dosya Seç
                            </button>
                        </div>
                        <input type="file" id="fileUpload" accept="image/*" style="display:none;" onchange="uploadSafeImage(this)" />
                        <small class="text-muted"><i class="fas fa-info-circle me-1"></i> Şeffaf arka planlı PNG dosyaları önerilir.</small>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted d-block mb-3">Logo Önizleme</label>
                    <div id="imagePreviewContainer" class="border rounded-3 p-4 bg-light d-flex align-items-center justify-content-center shadow-inner" style="min-height: 200px;">
                        <img id="previewImage" src="#" alt="Logo Önizleme" style="max-height: 120px; display: none;" class="img-fluid" />
                        <div id="previewPlaceholder" class="text-center">
                            <i class="fas fa-image fa-4x text-muted mb-2 opacity-25"></i>
                            <p class="text-muted small mb-0">Önizleme Bekleniyor</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5 pt-3 border-top">
                <button type="submit" class="btn btn-success px-4 py-2 me-2">
                    <i class="fas fa-save me-2"></i>Markayı Kaydet
                </button>
                <a href="@Url.Action("Index", "Markalar")" class="btn btn-outline-secondary px-4 py-2">
                    <i class="fas fa-times me-2"></i>Vazgeç
                </a>
            </div>
        }
    </div>
</div>

@section scripts {
    <script>
        function uploadSafeImage(input) {
            if (input.files && input.files[0]) {
                const formData = new FormData();
                formData.append('file', input.files[0]);
                
                // Add Anti-Forgery Token
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                formData.append('__RequestVerificationToken', token);

                const btn = document.querySelector('button[onclick*="fileUpload"]');
                const originalHtml = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Yükleniyor...';
                btn.disabled = true;

                fetch('@Url.Action("Image", "UploadSafe", new { area = "Admin" })', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const pathInput = document.getElementById('ResimYolu');
                        if (pathInput) {
                            pathInput.value = data.path;
                            updatePreview(data.path);
                        }
                    } else {
                        Swal.fire('Hata!', data.message, 'error');
                    }
                })
                .catch(error => {
                    console.error('Upload error:', error);
                    Swal.fire('Hata!', 'Yükleme sırasında bir hata oluştu.', 'error');
                })
                .finally(() => {
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                });
            }
        }

        function updatePreview(path) {
            const preview = document.getElementById('previewImage');
            const placeholder = document.getElementById('previewPlaceholder');
            if (path) {
                preview.src = path;
                preview.style.display = 'inline-block';
                placeholder.style.display = 'none';
            } else {
                preview.style.display = 'none';
                placeholder.style.display = 'block';
            }
        }

        document.getElementById('ResimYolu').addEventListener('input', function() {
            updatePreview(this.value);
        });
    </script>
}
