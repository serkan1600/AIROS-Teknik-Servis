@model AIROSWEB.DAL.Db.TblHizmetler
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Yeni Hizmet Ekle";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Yeni Hizmet Ekle</h4>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "Hizmetler", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="mb-3">
                 <label class="form-label">Başlık</label>
                 @Html.TextBoxFor(x => x.Baslik, new { @class = "form-control", required="required" })
            </div>
            <div class="mb-3">
                 <label class="form-label">İkon (FontAwesome Class)</label>
                 @Html.TextBoxFor(x => x.Ikon, new { @class = "form-control", placeholder="fa fa-cogs" })
                 <small class="text-muted">Örnek: fa fa-wrench, fa fa-snowflake</small>
            </div>
            <div class="mb-3">
                 <label class="form-label">Özet Açıklama (Kısa)</label>
                 @Html.TextAreaFor(x => x.Aciklama, new { @class = "form-control", rows=3 })
            </div>
            
             <!-- Yeni Alanlar -->
            <div class="mb-3">
                 <label class="form-label">Detaylı İçerik (Editör)</label>
                 @Html.TextAreaFor(x => x.Icerik, new { @class = "form-control", id="editor" })
                 <small class="text-muted">Buraya detaylı yazı, liste veya tablo ekleyebilirsiniz.</small>
            </div>

            <div class="mb-3">
                <label class="form-label">Hizmet Görseli</label>
                <div class="input-group">
                    @Html.TextBoxFor(x => x.ResimYolu, new { @class = "form-control", id="ResimYolu", placeholder="/Uploads/hizmet.jpg" })
                    <input type="file" id="fileInput" accept="image/*" style="display:none" onchange="uploadImage(this)" />
                    <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('fileInput').click()">
                        <i class="fas fa-upload"></i> Yükle
                    </button>
                </div>
                <div id="preview" class="mt-2"></div>
            </div>

            <div class="card bg-light border-0 mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="fas fa-search"></i> SEO Ayarları (Opsiyonel)</h5>
                    <div class="mb-2">
                        <label class="form-label">SEO Başlık</label>
                        @Html.TextBoxFor(x => x.MetaTitle, new { @class = "form-control" })
                    </div>
                    <div class="mb-2">
                        <label class="form-label">SEO Açıklama</label>
                        @Html.TextAreaFor(x => x.MetaDescription, new { @class = "form-control", rows = 2 })
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Anahtar Kelimeler</label>
                        @Html.TextBoxFor(x => x.Keywords, new { @class = "form-control", placeholder = "virgül ile ayırın" })
                    </div>
                </div>
            </div>

            <button class="btn btn-success"><i class="fas fa-save"></i> Kaydet</button>
        }
    </div>
</div>

@section scripts {
    <!-- CKEditor 5 CDN -->
    <script src="https://cdn.ckeditor.com/ckeditor5/38.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'insertTable', 'undo', 'redo'],
                language: 'tr'
            })
            .catch(error => {
                console.error(error);
            });
        function uploadImage(input) {
            if (input.files && input.files[0]) {
                var formData = new FormData();
                formData.append("file", input.files[0]);
                
                // Add Anti-Forgery Token
                formData.append("__RequestVerificationToken", $('input[name="__RequestVerificationToken"]').val());

                $.ajax({
                    url: '/Admin/UploadSafe/Image',
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (response.success) {
                            $("#ResimYolu").val(response.path);
                            $("#preview").html('<img src="' + response.path + '" style="max-height:150px; border-radius:10px; border:1px solid #ccc;" />');
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () {
                        alert("Yükleme sırasında hata oluştu.");
                    }
                });
            }
        }
    </script>
}
