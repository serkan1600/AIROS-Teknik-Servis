@{
    ViewBag.Title = "Sistem Kurulumu";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-tools me-2"></i>Sistem Kurulumu ve Onarım</h4>
                </div>
                <div class="card-body text-center py-5">
                    <i class="fas fa-database fa-4x text-muted mb-4"></i>
                    <h3>Veritabanı ve Sistem Onarımı</h3>
                    <p class="text-muted mb-4">Bu işlem eksik tabloları oluşturur, varsayılan admin kullanıcısını (admin/123456) kontrol eder ve temel site ayarlarını yapılandırır.</p>
                    
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm">
                            @TempData["Success"]
                        </div>
                    }

                    <div class="alert alert-warning border-0 shadow-sm text-start">
                        <strong><i class="fas fa-exclamation-triangle me-2"></i>Uyarı:</strong> 
                        Bu işlem veritabanı şemasını kontrol eder. Mevcut verileriniz silinmez, ancak eksik yapılandırmalar otomatik olarak tamamlanır.
                    </div>

                    @using (Html.BeginForm("RunSetup", "Setup", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                            <i class="fas fa-play me-2"></i>Onarımı Başlat
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
