@model List<AIROSWEB.DAL.Db.TblMusteriYorumlari>
@{
    ViewBag.Title = "Müşteri Yorumları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="fas fa-comments"></i> Müşteri Yorumları</h4>
        <a href="@Url.Action("Create", "Yorumlar")" class="btn btn-light text-primary btn-sm"><i class="fas fa-plus"></i> Yeni Yorum Ekle</a>
    </div>
    <div class="card-body">
        <table class="table table-hover table-bordered">
            <thead class="table-light">
                <tr>
                    <th width="50">#</th>
                    <th>Ad Soyad</th>
                    <th>Ünvan</th>
                    <th>Yorum</th>
                    <th>Puan</th>
                    <th>Durum</th>
                    <th width="150">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(item.ResimYolu))
                                {
                                    <img src="@item.ResimYolu" class="rounded-circle me-2" width="40" height="40" style="object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width:40px; height:40px;">
                                        <i class="fas fa-user"></i>
                                    </div>
                                }
                                <span>@item.AdSoyad</span>
                            </div>
                        </td>
                        <td>@item.Meslek</td>
                        <td>@(item.Yorum.Length > 50 ? item.Yorum.Substring(0, 50) + "..." : item.Yorum)</td>
                        <td>
                             @for(int i=0; i<item.Puan; i++) { <i class="fas fa-star text-warning"></i> }
                        </td>
                        <td>
                            @using (Html.BeginForm("DurumDegistir", "Yorumlar", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(item.AktifMi ? "btn-outline-success" : "btn-outline-danger")">
                                    @(item.AktifMi ? "Aktif" : "Pasif")
                                </button>
                            }
                        </td>
                        <td>
                            <div class="btn-group">
                                <a href="@Url.Action("Edit", "Yorumlar", new { id = item.Id })" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                @using (Html.BeginForm("Delete", "Yorumlar", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Silmek istediğinize emin misiniz?');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm border-start-0 rounded-start-0"><i class="fas fa-trash"></i></button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
