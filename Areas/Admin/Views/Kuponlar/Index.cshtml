@model IEnumerable<AIROSWEB.DAL.Db.TblKuponlar>
@{
    ViewBag.Title = "İndirim Kuponları Modülü";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-ticket-alt"></i> İndirim Kuponları Yönetimi</h6>
        <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="fas fa-plus"></i> Yeni Kupon Oluştur
        </button>
    </div>
    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
        }

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Kupon Kodu</th>
                        <th>Açıklama</th>
                        <th>İndirim</th>
                        <th>Son Kullanma</th>
                        <th>Kullanım</th>
                        <th>Durum</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-dark fw-bold" style="font-size: 1rem;">@item.Kod</span></td>
                            <td>@item.Aciklama</td>
                            <td>
                                @if (item.IndirimOrani > 0)
                                {
                                    <span class="text-primary fw-bold">%@item.IndirimOrani İndirim</span>
                                }
                                else if (item.Miktar > 0)
                                {
                                    <span class="text-primary fw-bold">@item.Miktar TL İndirim</span>
                                }
                            </td>
                            <td>
                                @if (item.SonKullanmaTarihi.HasValue)
                                {
                                    <span class="@(item.SonKullanmaTarihi.Value < DateTime.Now ? "text-danger text-decoration-line-through" : "")">
                                        @item.SonKullanmaTarihi.Value.ToString("dd.MM.yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Süresiz</span>
                                }
                            </td>
                            <td><span class="badge bg-info text-dark">@item.KullanimSayisi kez</span></td>
                            <td>
                                <div class="form-check form-switch custom-switch-primary">
                                    <input class="form-check-input status-toggle" type="checkbox" role="switch" data-id="@item.Id" @(item.AktifMi ? "checked" : "")>
                                </div>
                            </td>
                            <td>
                                @using (Html.BeginForm("Delete", "Kuponlar", new { id = item.Id }, FormMethod.Post, new { style = "display:inline;", onsubmit = "return confirm('Bu kuponu silmek istediğinize emin misiniz?');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if(!Model.Any())
            {
                <div class="alert alert-warning text-center">Henüz sisteme tanımlanmış bir indirim kuponu bulunmamaktadır.</div>
            }
        </div>
    </div>
</div>

<!-- Yeni Kupon Ekle Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-plus"></i> Yeni Kupon Oluştur</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Create", "Kuponlar", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Kupon Kodu (Örn: KIS2026)</label>
                        <input type="text" name="Kod" class="form-control text-uppercase" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Kampanya Açıklaması</label>
                        <input type="text" name="Aciklama" class="form-control" placeholder="Örn: Kış bakımı %20 indirim" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Yüzdelik İndirim (%)</label>
                            <input type="number" name="IndirimOrani" class="form-control" value="0" min="0" max="100" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Veya Sabit Fiyat (TL)</label>
                            <input type="number" name="Miktar" class="form-control" value="0" min="0" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Son Kullanma Tarihi (Opsiyonel)</label>
                        <input type="date" name="SonKullanmaTarihi" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Kaydet ve Aktifleştir</button>
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
<script>
    document.addEventListener("DOMContentLoaded", function() {
        document.querySelectorAll('.status-toggle').forEach(t => {
            t.addEventListener('change', function() {
                var id = this.getAttribute('data-id');
                var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if(!token) {
                    token = document.querySelector('#__AjaxAntiForgeryForm input[name="__RequestVerificationToken"]')?.value;
                }
                
                fetch('/Admin/Kuponlar/ToggleStatus/' + id, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                }).then(r => r.json()).then(res => {
                    if(!res.success) {
                        alert('Güncellenirken hata oluştu.');
                        this.checked = !this.checked;
                    }
                });
            });
        });
    });
</script>
}
