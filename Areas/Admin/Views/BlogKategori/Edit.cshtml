@model AIROSWEB.DAL.Db.TblBlogKategori
@{
    ViewBag.Title = "Kategori Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0"><i class="fas fa-edit"></i> Kategori Düzenle</h4>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Edit", "BlogKategori", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)
            
            <div class="mb-3">
                <label class="form-label fw-bold">Kategori Adı</label>
                @Html.TextBoxFor(m => m.KategoriAdi, new { @class = "form-control", required = "required" })
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Slug</label>
                @Html.TextBoxFor(m => m.Slug, new { @class = "form-control" })
            </div>
            <div class="mb-3">
                <div class="form-check form-switch">
                    @Html.CheckBoxFor(m => m.AktifMi, new { @class = "form-check-input" })
                    <label class="form-check-label">Aktif</label>
                </div>
            </div>

            <hr />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Güncelle
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Geri
                </a>
            </div>
        }
    </div>
</div>
