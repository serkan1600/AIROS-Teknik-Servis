@model List<AIROSWEB.DAL.Db.TblBlogKategori>
@{
    ViewBag.Title = "Blog Kategorileri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-plus"></i> Yeni Kategori</h5>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Create", "BlogKategori", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Kategori Adı</label>
                        @Html.TextBox("KategoriAdi", null, new { @class = "form-control", required = "required", placeholder = "Örn: Kombi Bakımı" })
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Slug (URL)</label>
                        @Html.TextBox("Slug", null, new { @class = "form-control", placeholder = "Otomatik oluşturulacak" })
                        <small class="text-muted">Boş bırakabilirsiniz</small>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            @Html.CheckBox("AktifMi", true, new { @class = "form-check-input" })
                            <label class="form-check-label">Aktif</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fas fa-save"></i> Kaydet
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-folder"></i> Kategoriler</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Kategori Adı</th>
                                    <th>Slug</th>
                                    <th width="100">Durum</th>
                                    <th width="150">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><strong>@item.KategoriAdi</strong></td>
                                        <td><code>/@item.Slug</code></td>
                                        <td>
                                            @if (item.AktifMi)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Pasif</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-warning">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                @using (Html.BeginForm("Delete", "BlogKategori", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Silmek istediğinize emin misiniz?');" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger btn-sm">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-folder-open fa-4x text-muted mb-3"></i>
                        <p class="text-muted">Henüz kategori bulunmuyor.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
