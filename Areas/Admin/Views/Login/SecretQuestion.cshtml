@{
    Layout = null;
    ViewBag.Title = "Gizli Soru ile Şifre Sıfırla";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>AIROS - Gizli Soru ile Kurtarma</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        body { background-color: #f0f2f5; display: flex; align-items: center; justify-content: center; height: 100vh; font-family: 'Segoe UI', sans-serif; }
        .login-card { width: 450px; padding: 40px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); background: white; }
        .login-header { text-align: center; margin-bottom: 30px; }
        .login-header h3 { color: #dc3545; font-weight: bold; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-user-shield fa-3x text-danger mb-3"></i>
            <h3>G&#304;ZL&#304; SORU DO&#286;RULAMA</h3>
            <p class="text-muted">Kullanıcı adınızı girerek şifrenizi sıfırlayın.</p>
        </div>

        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Hata</div>
        }

        <form id="recoveryForm" method="post" action="@Url.Action("SecretQuestion", "Login")">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-bold">Kullanıcı Adı</label>
                <div class="input-group">
                    <input type="text" id="kullaniciAdi" name="kullaniciAdi" class="form-control" value="@ViewBag.KullaniciAdi" placeholder="admin" required />
                    <button class="btn btn-outline-secondary" type="button" id="btnGetQuestion">Soru Getir</button>
                </div>
            </div>

            <div id="questionSection" style="@(string.IsNullOrEmpty(ViewBag.Soru) ? "display:none;" : "")">
                <div class="mb-3 bg-light p-3 rounded border">
                    <label class="form-label fw-bold text-danger">Gizli Sorunuz:</label>
                    <p id="txtSoru" class="mb-0 fw-bold">@ViewBag.Soru</p>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Cevabınız</label>
                    <input type="text" name="cevap" class="form-control" placeholder="Cevabı buraya yazın..." required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Yeni Şifreniz</label>
                    <input type="password" name="yeniSifre" class="form-control" placeholder="******" required minlength="6" />
                </div>

                <button type="submit" class="btn btn-danger w-100 btn-lg fw-bold mb-3">&#350;&#304;FREY&#304; SIFIRLA VE KAYDET</button>
            </div>

            <a href="@Url.Action("Index", "Login")" class="btn btn-outline-secondary w-100"><i class="fas fa-arrow-left me-2"></i>Giri&#351; Sayfas&#305;na D&#214;n</a>
        </form>
    </div>

    <script>
        $(document).ready(function() {
            $("#btnGetQuestion").click(function() {
                var kAdi = $("#kullaniciAdi").val();
                if(!kAdi) { alert("Lütfen kullanıcı adınızı girin."); return; }

                $.ajax({
                    url: '@Url.Action("GetSecretQuestion", "Login")',
                    type: 'POST',
                    data: { kullaniciAdi: kAdi },
                    success: function(res) {
                        if(res.success) {
                            $("#txtSoru").text(res.soru);
                            $("#questionSection").slideDown();
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function() {
                        alert("Sunucuyla iletişim kurulurken bir hata oluştu.");
                    }
                });
            });
        });
    </script>
</body>
</html>
