@model IEnumerable<AIROSWEB.DAL.Db.TblHizmetBolgeleri>
@{
    ViewBag.Title = "Hizmet Verdiğimiz Yerler Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="fas fa-map-marked-alt"></i> Hizmet Verdiğimiz Yerler (İlçeler)</h4>
        <a href="@Url.Action("Create")" class="btn btn-light btn-sm fw-bold">
            <i class="fas fa-plus"></i> Yeni Bölge Ekle
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">Sıra</th>
                        <th>Bölge / İlçe Adı</th>
                        <th style="width: 100px;">Durum</th>
                        <th style="width: 150px;" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Sira</td>
                            <td>
                                <div class="fw-bold">@item.BolgeAdi</div>
                                <small class="text-muted">/@(item.Slug ?? AIROSWEB.Helpers.SeoHelper.ToSeoUrl(item.BolgeAdi))</small>
                            </td>
                            <td>
                                @if (item.AktifMi)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="/Bursa-Teknik-Servis/@(item.Slug ?? AIROSWEB.Helpers.SeoHelper.ToSeoUrl(item.BolgeAdi))" target="_blank" class="btn btn-sm btn-outline-info" title="Sayfayı Gör">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @using (Html.BeginForm("Delete", "HizmetBolgeleri", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Bu bölgeyi silmek istediğinize emin misiniz?');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-start-0 rounded-start-0" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
