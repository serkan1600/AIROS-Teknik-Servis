@model AIROSWEB.DAL.Db.TblHizmetBolgeleri
@{
    ViewBag.Title = Model.Id == 0 ? "Yeni Bölge Ekle" : "Bölge Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="fas fa-edit"></i> @ViewBag.Title</h4>
            </div>
            <div class="card-body">
                @using (Html.BeginForm(Model.Id == 0 ? "Create" : "Edit", "HizmetBolgeleri", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.Id)

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Bölge / İlçe Adı</label>
                            @Html.TextBoxFor(m => m.BolgeAdi, new { @class = "form-control form-control-lg", placeholder = "Örn: Osmangazi", required = "required", onkeyup = "generateSlug(this.value)" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">SEO Link (Slug)</label>
                            @Html.TextBoxFor(m => m.Slug, new { @class = "form-control form-control-lg", id = "Slug", placeholder = "osmangazi-teknik-servis" })
                        </div>
                    </div>

                    <div class="card bg-light border-0 mb-4">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3"><i class="fas fa-search text-info"></i> SEO Ayarları (Arama Motoru Görünümü)</h6>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Meta Başlık (Title)</label>
                                @Html.TextBoxFor(m => m.MetaTitle, new { @class = "form-control", placeholder = "Örn: Osmangazi Kombi Servisi - 7/24 Teknik Destek" })
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Meta Açıklama (Description)</label>
                                @Html.TextAreaFor(m => m.MetaDescription, new { @class = "form-control", rows = "2", placeholder = "Google sonuçlarında görünecek kısa açıklama..." })
                            </div>
                            <div class="mb-0">
                                <label class="form-label small fw-bold">Meta Anahtar Kelimeler (Keywords)</label>
                                @Html.TextBoxFor(m => m.Keywords, new { @class = "form-control", placeholder = "kombi servisi, klima bakımı, osmangazi teknik servis" })
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Kısa Açıklama (Liste Sayfası İçin)</label>
                        @Html.TextAreaFor(m => m.Aciklama, new { @class = "form-control", rows = "2" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Detaylı Bölge İçeriği (Alt Bölüm)</label>
                        @Html.TextAreaFor(m => m.Icerik, new { @class = "form-control", id = "editor" })
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Görüntüleme Sırası</label>
                            @Html.TextBoxFor(m => m.Sira, new { @class = "form-control", type = "number" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Durum</label>
                            <div class="form-check form-switch mt-2">
                                @Html.CheckBoxFor(m => m.AktifMi, new { @class = "form-check-input", role = "switch" })
                                <label class="form-check-label">Sitede Göster</label>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Geri Dön
                        </a>
                        <button type="submit" class="btn btn-primary px-5 btn-lg shadow">
                            <i class="fas fa-plus-circle"></i> Bölgeyi Oluştur
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
    <!-- CKEditor 5 CDN -->
    <script src="https://cdn.ckeditor.com/ckeditor5/38.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'insertTable', 'undo', 'redo'],
                language: 'tr'
            })
            .catch(error => {
                console.error(error);
            });

        function generateSlug(text) {
            const slugInput = document.getElementById('Slug');
            if (slugInput.dataset.manual === "true") return;

            var slug = text.toLowerCase()
                .replace(/ğ/g, 'g').replace(/ü/g, 'u').replace(/ş/g, 's').replace(/ı/g, 'i').replace(/ö/g, 'o').replace(/ç/g, 'c')
                .replace(/[^a-z0-9]/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
            slugInput.value = slug;
        }

        document.getElementById('Slug').addEventListener('input', function() {
            this.dataset.manual = "true";
        });
    </script>
}

