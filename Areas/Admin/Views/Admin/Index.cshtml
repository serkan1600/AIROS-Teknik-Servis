@model IEnumerable<AIROSWEB.DAL.Db.TblAdmin>
@{
    ViewBag.Title = "Yöneticiler ve Personeller";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-users-cog me-2"></i> Sistem Kullanıcıları</h6>
        <a href="@Url.Action("Create")" class="btn btn-sm btn-success shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Ekle
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="bg-light">
                    <tr>
                        <th>Kullanıcı Adı</th>
                        <th>Rol</th>
                        <th>E-posta</th>
                        <th>Durum</th>
                        <th width="150" class="text-center">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@item.KullaniciAdi</td>
                            <td>
                                @if (item.Rol == "Admin")
                                {
                                    <span class="badge bg-danger"><i class="fas fa-shield-alt"></i> Admin</span>
                                }
                                else if (item.Rol == "Teknisyen")
                                {
                                    <span class="badge bg-info text-dark"><i class="fas fa-tools"></i> Teknisyen</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Rol</span>
                                }
                            </td>
                            <td>@(item.Email ?? "-")</td>
                            <td>
                                @if (item.AktifMi == true)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-primary" title="Düzenle">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @if (Session["AdminId"]?.ToString() != item.Id.ToString())
                                {
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </button>

                                    <!-- Silme Modalı -->
                                    <div class="modal fade text-start" id="deleteModal-@item.Id" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Kullanıcıyı Sil</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <strong>@item.KullaniciAdi</strong> adlı personeli sistemden silmek istediğinize emin misiniz?
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                                                    @using (Html.BeginForm("Delete", "Admin", new { id = item.Id }, FormMethod.Post))
                                                    {
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-danger">Evet, Sil</button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
