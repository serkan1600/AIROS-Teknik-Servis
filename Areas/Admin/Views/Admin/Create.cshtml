@model AIROSWEB.DAL.Db.TblAdmin
@{
    ViewBag.Title = "Yeni Personel Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-white">
                <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-user-plus me-2"></i> Yeni Personel Ekle</h6>
            </div>
            <div class="card-body">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Kullanıcı Adı <span class="text-danger">*</span></label>
                        @Html.TextBoxFor(x => x.KullaniciAdi, new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(x => x.KullaniciAdi, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Şifre <span class="text-danger">*</span></label>
                        @Html.PasswordFor(x => x.Sifre, new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(x => x.Sifre, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">E-Posta (İsteğe Bağlı)</label>
                        @Html.TextBoxFor(x => x.Email, new { @class = "form-control", type = "email" })
                    </div>

                    <div class="mb-4">
                        <label class="form-label font-weight-bold">Personel Yetkisi (Rolü) <span class="text-danger">*</span></label>
                        <select name="Rol" class="form-select border-info" required>
                            <option value="Admin">Tam Yetkili Portal Yöneticisi (Admin)</option>
                            <option value="Teknisyen" selected>Sahadaki Teknisyen / Ustabaşı</option>
                        </select>
                        <small class="text-muted d-block mt-1">
                            <strong><i class="fas fa-info-circle"></i> Teknisyen Rolü:</strong> Bu yetkiyle giriş yapan kişi portalın yönetim ayarlarını göremez, sadece kendisine atanan işleri görür ve durumu günceller.
                        </small>
                    </div>

                    <hr />
                    <button type="submit" class="btn btn-success fw-bold w-100">
                        <i class="fas fa-save me-2"></i> Kaydet ve Sisteme Ekle
                    </button>
                    <div class="text-center mt-3">
                        <a href="@Url.Action("Index")" class="text-muted text-decoration-none">Listeye Geri Dön</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
