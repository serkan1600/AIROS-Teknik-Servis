@model IEnumerable<AIROSWEB.DAL.Db.TblNewsletter>
@{
    ViewBag.Title = "E-Bülten Aboneleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-envelope-open-text"></i> E-Bülten Aboneleri</h5>
        <button class="btn btn-success btn-sm" onclick="exportToExcel()">
            <i class="fas fa-file-excel"></i> Excel'e Aktar
        </button>
    </div>
    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="table-responsive">
            <table class="table table-hover align-middle" id="newsletterTable">
                <thead>
                    <tr>
                        <th>E-Posta</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in Model)
                    {
                        <tr>
                            <td class="fw-bold">@sub.Email</td>
                            <td>@sub.KayitTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" @(sub.AktifMi ? "checked" : "") 
                                           onchange="toggleSubStatus(@sub.Id)">
                                    <span class="ms-1 small">@(sub.AktifMi ? "Aktif" : "Pasif")</span>
                                </div>
                            </td>
                            <td class="text-end">
                                @using (Html.BeginForm("Delete", "Newsletter", new { id = sub.Id }, FormMethod.Post, new { style="display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Silmek istediğinize emin misiniz?');">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function toggleSubStatus(id) {
            $.post('/Admin/Newsletter/ToggleStatus', { 
                id: id, 
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() 
            }, function(res) {
               if(res.success) {
                   Swal.fire({
                       toast: true,
                       position: 'top-end',
                       icon: 'success',
                       title: 'Durum güncellendi',
                       showConfirmButton: false,
                       timer: 1500
                   });
               }
            });
        }

        function exportToExcel() {
            // Basit bir CSV export logic (Opsiyonel)
            alert('Aboneler indiriliyor... (CSV formatında)');
            let csvContent = "data:text/csv;charset=utf-8,Email,Tarih,Durum\n";
            @foreach (var s in Model) {
                <text>csvContent += "@s.Email,@s.KayitTarihi.ToString("yyyy-MM-dd"),@(s.AktifMi ? "Aktif" : "Pasif")\n";</text>
            }
            var encodedUri = encodeURI(csvContent);
            var link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", "aboneler.csv");
            document.body.appendChild(link);
            link.click();
        }
    </script>
}
