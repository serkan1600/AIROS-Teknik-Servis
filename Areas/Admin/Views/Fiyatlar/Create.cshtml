@model AIROSWEB.DAL.Db.TblArizaFiyatlari
@{
    ViewBag.Title = "Yeni Arıza/Fiyat Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="h3 mb-0 text-gray-800"><i class="fas fa-plus text-primary"></i> Yeni Fiyat/Arıza Kaydı Ekle</h2>
            <p class="text-muted mb-0">Web sitesi üzerindeki fiyat hesaplama sihirbazı için yeni bir seçenek oluşturun.</p>
        </div>
        <a href="/Admin/Fiyatlar/Index" class="btn btn-secondary shadow-sm"><i class="fas fa-arrow-left fa-sm text-white-50"></i> Geri Dön</a>
    </div>
</div>

<div class="card shadow mb-4 border-0">
    <div class="card-body">
        @using (Html.BeginForm("Create", "Fiyatlar", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label class="form-label fw-bold">Cihaz Türü <span class="text-danger">*</span></label>
                    <input type="text" name="CihazTuru" list="cihazList" class="form-control" required placeholder="Örn: Kombi veya TV" />
                    <datalist id="cihazList">
                        @if (ViewBag.Cihazlar != null)
                        {
                            foreach (var cihaz in (List<string>)ViewBag.Cihazlar)
                            {
                                if (!string.IsNullOrEmpty(cihaz))
                                {
                                    <option value="@cihaz"></option>
                                }
                            }
                        }
                    </datalist>
                </div>
                
                <div class="col-md-3 mb-3">
                    <label class="form-label fw-bold">Marka (Opsiyonel)</label>
                    <input type="text" name="Marka" class="form-control" placeholder="Örn: Bosch veya Tümü bırakın" />
                    <small class="text-muted">Boş bırakılırsa tüm markalar için geçerli olur.</small>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Arıza / Hizmet Adı <span class="text-danger">*</span></label>
                    @Html.TextBoxFor(m => m.ArizaAdi, new { @class = "form-control", required = "required", placeholder = "Örn: Yıllık Periyodik Bakım" })
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Fiyat Aralığı <span class="text-danger">*</span></label>
                    @Html.TextBoxFor(m => m.FiyatAraligi, new { @class = "form-control", required = "required", placeholder = "Örn: ₺1.000 - ₺1.500" })
                    <small class="text-success fw-bold">Fiyat tahmini aralığı girin.</small>
                </div>

                <div class="col-md-2 mb-3">
                    <label class="form-label fw-bold">Sıralama Gösterimi</label>
                    @Html.TextBoxFor(m => m.Sira, new { @class = "form-control", type = "number", value = "99" })
                </div>

                <div class="col-md-3 mb-3 d-flex align-items-center">
                    <div class="form-check form-switch fs-5 mt-4">
                        @Html.CheckBoxFor(m => m.AktifMi, new { @class = "form-check-input", id = "AktifMi" })
                        <label class="form-check-label ms-2 mt-1" for="AktifMi">Aktif (Yayında İşaretli Olsun mu?)</label>
                    </div>
                </div>
            </div>

            <hr class="my-4">
            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm fw-bold"><i class="fas fa-save me-2"></i> KAYDET VEYA OLUŞTUR</button>
        }
    </div>
</div>
