@model IEnumerable<AIROSWEB.DAL.Db.TblArizaFiyatlari>
@{
    ViewBag.Title = "Dinamil Fiyat/Arıza Kataloğu";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="h3 mb-0 text-gray-800"><i class="fas fa-money-bill-wave text-primary"></i> Fiyat & Arıza Sihirbazı Kataloğu</h2>
            <p class="text-muted mb-0">Web sitesindeki "Fiyat Hesaplatma" sihirbazında görünen seçenekleri buradan yönetebilirsiniz.</p>
        </div>
        <a href="/Admin/Fiyatlar/Create" class="btn btn-primary shadow-sm"><i class="fas fa-plus fa-sm text-white-50"></i> Yeni Fiyat/Arıza Ekle</a>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th width="50">ID</th>
                        <th width="120">Cihaz Türü</th>
                        <th width="150">Marka</th>
                        <th>Arıza / Şikayet Adı</th>
                        <th width="150">Fiyat Aralığı</th>
                        <th width="80">Sıra</th>
                        <th width="100" class="text-center">Durum</th>
                        <th width="120" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr id="row_@item.Id">
                            <td>@item.Id</td>
                            <td><span class="badge @(item.CihazTuru == "Kombi" ? "bg-primary" : item.CihazTuru == "Klima" ? "bg-info" : "bg-secondary")">@item.CihazTuru</span></td>
                            <td>@(string.IsNullOrEmpty(item.Marka) ? "Tümü" : item.Marka)</td>
                            <td class="fw-bold">@item.ArizaAdi</td>
                            <td class="text-success fw-bold">@item.FiyatAraligi</td>
                            <td>@item.Sira</td>
                            <td class="text-center">
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input status-switch" type="checkbox" role="switch" data-id="@item.Id" @(item.AktifMi ? "checked" : "")>
                                </div>
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="/Admin/Fiyatlar/Edit/@item.Id" class="btn btn-sm btn-info text-white" title="Düzenle">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="btn btn-sm btn-danger btn-delete" data-id="@item.Id" title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Turkish.json" },
                "order": [[1, "asc"], [5, "asc"]]
            });

            // Delete
            $('.btn-delete').click(function () {
                var btn = $(this);
                var id = btn.data('id');
                Swal.fire({
                    title: 'Emin misiniz?',
                    text: "Bu fiyat kaydı silinecek. Web sitesinden kaldırılacaktır!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Evet, Sil!',
                    cancelButtonText: 'İptal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post('/Admin/Fiyatlar/Delete/' + id, function (data) {
                            if (data.success) {
                                Swal.fire('Silindi!', data.message, 'success');
                                $('#row_' + id).fadeOut();
                            } else {
                                Swal.fire('Hata!', data.message, 'error');
                            }
                        });
                    }
                });
            });

            // Status Switch
            $('.status-switch').change(function () {
                var id = $(this).data('id');
                $.post('/Admin/Fiyatlar/ChangeStatus/' + id, function (data) {
                    if (!data.success) {
                        Swal.fire('Hata!', data.message, 'error');
                    }
                });
            });
        });
    </script>
}
