@model IEnumerable<AIROSWEB.DAL.Db.TblSecurityLogs>
@{
    ViewBag.Title = "Güvenlik Günlükleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-danger">
    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-shield-alt"></i> Güvenlik Günlükleri</h5>
        @using (Html.BeginForm("ClearSecurity", "Logs", FormMethod.Post, new { onsubmit = "return confirm('Tüm güvenlik kayıtlarını silmek istediğinize emin misiniz?');" }))
        {
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning btn-sm text-dark">
                <i class="fas fa-eraser"></i> Temizle
            </button>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Kullanıcı</th>
                        <th>İşlem</th>
                        <th>Durum</th>
                        <th>Cihaz/Tarayıcı</th>
                        <th>IP</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="small">@log.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-bold">@log.KullaniciAdi</td>
                            <td>@log.Islem</td>
                            <td>
                                @if (log.Durum == "Başarılı")
                                {
                                    <span class="badge bg-success"><i class="fas fa-check"></i> Başarılı</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="fas fa-times"></i> Başarısız</span>
                                }
                            </td>
                            <td class="small text-muted" title="@log.Tarayici">
                                @(log.Tarayici != null && log.Tarayici.Length > 30 ? log.Tarayici.Substring(0, 30) + "..." : log.Tarayici)
                            </td>
                            <td><code>@log.Ip</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
