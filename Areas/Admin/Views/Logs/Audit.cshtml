@model IEnumerable<AIROSWEB.DAL.Db.TblAuditLogs>
@{
    ViewBag.Title = "İşlem Günlükleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-history"></i> İşlem Günlükleri (Audit Trail)</h5>
        @using (Html.BeginForm("ClearAudit", "Logs", FormMethod.Post, new { onsubmit = "return confirm('Tüm işlem kayıtlarını silmek istediğinize emin misiniz?');" }))
        {
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="fas fa-trash"></i> Tümünü Temizle
            </button>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Kullanıcı</th>
                        <th>İşlem</th>
                        <th>Tablo</th>
                        <th>ID</th>
                        <th>Detay</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="small">@log.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="badge bg-secondary">@log.Kullanici</span></td>
                            <td>
                                @{
                                    string color = log.Islem == "Ekleme" ? "success" : log.Islem == "Güncelleme" ? "info" : log.Islem == "Silme" ? "danger" : "primary";
                                }
                                <span class="badge bg-@color">@log.Islem</span>
                            </td>
                            <td class="small">@log.Tablo</td>
                            <td>@log.KayitId</td>
                            <td class="small">@log.Detay</td>
                            <td class="text-muted small">@log.Ip</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
