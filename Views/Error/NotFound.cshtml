@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Sayfa Bulunamadı - 404</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; height: 100vh; text-align: center; }
        .error-code { font-size: 8rem; font-weight: 900; color: #dc3545; }
        .error-message { font-size: 1.5rem; color: #6c757d; margin-bottom: 2rem; }
    </style>
</head>
<body>
    <div class="container">
        <div class="error-code animate__animated animate__bounceIn">404</div>
        <h1 class="display-4 fw-bold text-dark">Aradığınız Sayfa Bulunamadı</h1>
        <p class="error-message">Gitmek istediğiniz sayfa kaldırılmış veya adı değiştirilmiş olabilir.</p>
        <a href="/" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
            <i class="fas fa-home me-2"></i>Anasayfaya Dön
        </a>
    </div>
</body>
</html>
