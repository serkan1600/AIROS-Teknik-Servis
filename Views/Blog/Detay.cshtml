@model AIROSWEB.Models.LayoutViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var blog = Model.BlogDetay;
    ViewBag.Title = blog.MetaTitle ?? blog.Baslik;
    ViewBag.Description = blog.MetaDescription ?? blog.Ozet;
    ViewBag.Keywords = blog.Keywords;
}

<section class="page-header py-5 bg-dark text-white text-center" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('@(string.IsNullOrEmpty(blog.ResimYolu) ? "https://images.unsplash.com/photo-1499750310107-5fef28a66643?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200" : blog.ResimYolu)'); background-size: cover; background-position: center;">
    <div class="container animate__animated animate__fadeInDown">
        <div class="mb-3">
            <span class="badge bg-primary px-3 py-2 rounded-pill">
                @{
                    var kat = Model.Kategoriler.FirstOrDefault(x => x.Id == blog.KategoriId);
                    @(kat?.KategoriAdi ?? "Genel")
                }
            </span>
        </div>
        <h1 class="display-4 fw-bold">@blog.Baslik</h1>
        <div class="d-flex justify-content-center align-items-center text-white-50 mt-4">
            <div class="me-4"><i class="far fa-calendar-alt me-2"></i> @blog.YayinTarihi.ToString("dd MMMM yyyy")</div>
            <div class="me-4"><i class="far fa-user me-2"></i> @(blog.Yazar ?? "Airos Teknik")</div>
            <div><i class="far fa-eye me-2"></i> @blog.GoruntulemeSayisi Okunma</div>
        </div>
    </div>
</section>

<div class="container py-5">
    <div class="row">
        <!-- Content Area -->
        <div class="col-lg-8">
            <div class="blog-content-wrapper animate__animated animate__fadeInUp">
                @if (!string.IsNullOrEmpty(blog.ResimYolu))
                {
                    <img src="@blog.ResimYolu" class="img-fluid rounded-4 shadow-sm mb-5 w-100" alt="@blog.Baslik">
                }

                <div class="blog-main-text fs-5 lh-lg text-secondary">
                    @Html.Raw(blog.Icerik)
                </div>

                <!-- Paylaşım -->
                <div class="share-box border-top border-bottom py-4 my-5 d-flex align-items-center justify-content-between">
                    <span class="fw-bold text-dark">Bu yazıyı paylaşın:</span>
                    <div class="share-buttons">
                        <a href="https://www.facebook.com/sharer/sharer.php?u=@Request.Url" target="_blank" class="btn btn-outline-secondary btn-sm rounded-circle me-2"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://twitter.com/intent/tweet?url=@Request.Url&text=@blog.Baslik" target="_blank" class="btn btn-outline-secondary btn-sm rounded-circle me-2"><i class="fab fa-twitter"></i></a>
                        <a href="https://wa.me/?text=@blog.Baslik @Request.Url" target="_blank" class="btn btn-outline-secondary btn-sm rounded-circle"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
            </div>

            <!-- Yorumlar Bölümü -->
            <div class="comments-section mt-5 animate__animated animate__fadeInUp">
                <h4 class="fw-bold mb-4">Yorumlar (@(blog.Yorumlar != null ? blog.Yorumlar.Count : 0))</h4>
                
                @if (blog.Yorumlar != null && blog.Yorumlar.Any())
                {
                    <div class="list-group list-group-flush mb-5">
                        @foreach (var yorum in blog.Yorumlar)
                        {
                            <div class="list-group-item border-0 bg-light rounded-4 mb-3 p-4 shadow-sm">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                                        <span class="fs-4 fw-bold">@yorum.AdSoyad.Substring(0, 1)</span>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0">@yorum.AdSoyad</h6>
                                        <small class="text-muted">@yorum.Tarih.ToString("dd MMMM yyyy HH:mm")</small>
                                    </div>
                                </div>
                                <div class="mb-0 text-secondary ps-5 ms-3">@Html.Raw(yorum.Yorum)</div>

                                @if (!string.IsNullOrEmpty(yorum.YoneticiCevabi))
                                {
                                    <div class="mt-3 ms-5 p-3 bg-white rounded-3 border-start border-4 border-primary shadow-sm">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
                                                <i class="fas fa-user-shield small"></i>
                                            </div>
                                            <div>
                                                <span class="fw-bold text-primary small">Yönetici Cevabı</span>
                                                <small class="text-muted ms-2" style="font-size: 0.75rem;">@(yorum.CevapTarihi.HasValue ? yorum.CevapTarihi.Value.ToString("dd.MM.yyyy HH:mm") : "")</small>
                                            </div>
                                        </div>
                                        <div class="mb-0 text-dark small">@Html.Raw(yorum.YoneticiCevabi)</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-light text-center border-0 shadow-sm rounded-4 p-4 mb-5">
                        <i class="fas fa-comment-slash fa-2x text-muted mb-3"></i>
                        <p class="mb-0 text-muted">Henüz yorum yapılmamış. İlk yorumu siz yapın!</p>
                    </div>
                }

                <!-- Yorum Formu -->
                <div class="card border-0 shadow-sm rounded-4 bg-white p-5">
                    <h5 class="fw-bold mb-4">Bir Yorum Bırakın</h5>
                    
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            <i class="fas fa-check-circle"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @using (Html.BeginForm("YorumYap", "Blog", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("BlogId", blog.Id)
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">Adınız Soyadınız *</label>
                                <input type="text" name="AdSoyad" class="form-control rounded-pill bg-light border-0 py-3 px-4" required placeholder="Adınız Soyadınız">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">E-Posta Adresiniz (Yayınlanmaz)</label>
                                <input type="email" name="Email" class="form-control rounded-pill bg-light border-0 py-3 px-4" placeholder="ornek@email.com">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-uppercase">Yorumunuz *</label>
                                <textarea name="Yorum" class="form-control rounded-4 bg-light border-0 p-4" rows="4" required placeholder="Yorumunuzu buraya yazın..."></textarea>
                            </div>
                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow fw-bold">
                                    <i class="fas fa-paper-plane me-2"></i> Gönder
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Diğer Yazılar -->
            <div class="mt-5">
                <h4 class="fw-bold mb-4">İlginizi Çekebilir</h4>
                <div class="row g-4">
                    @foreach (var related in Model.Bloglar)
                    {
                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                                <img src="@(string.IsNullOrEmpty(related.ResimYolu) ? "https://via.placeholder.com/400x250" : related.ResimYolu)" class="card-img-top" alt="@related.Baslik" style="height: 150px; object-fit: cover;">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold mb-2">
                                        <a href="@Url.Action("Detay", "Blog", new { id = related.Slug })" class="text-decoration-none text-dark hover-primary">@related.Baslik</a>
                                    </h6>
                                    <small class="text-muted">@related.YayinTarihi.ToString("dd.MM.yyyy")</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4 mt-5 mt-lg-0">
            <div class="sticky-top" style="top: 100px;">
                <!-- Kategori Widget -->
                <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="fw-bold mb-0">Kategoriler</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var category in Model.Kategoriler)
                            {
                                <a href="@Url.Action("Index", "Blog", new { kategoriId = category.Id })" class="list-group-item list-group-item-action">
                                    @category.KategoriAdi
                                </a>
                            }
                        </div>
                    </div>
                </div>

                <!-- Randevu Widget -->
                <div class="card border-0 bg-warning text-dark p-4 rounded-4 shadow mb-4">
                    <h5 class="fw-bold mb-3">Randevu Almak İster Misiniz?</h5>
                    <p class="small mb-4">Hızlı ve güvenilir servis için online randevu formu doldurabilir veya bizi arayabilirsiniz.</p>
                    <a href="@Url.Action("Randevu", "Home")" class="btn btn-dark rounded-pill w-100 fw-bold mb-2">Randevu Formu</a>
                    <a href="tel:@(Model.Ayarlar?.Telefon?.Replace(" ", "") ?? "05010022516")" class="btn btn-outline-dark rounded-pill w-100 fw-bold">Hemen Ara</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .blog-main-text p { margin-bottom: 1.5rem; }
    .hover-primary:hover { color: #0d6efd !important; }
    .share-buttons .btn:hover { background-color: #0d6efd; color: white; border-color: #0d6efd; }
</style>
