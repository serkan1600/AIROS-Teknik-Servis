@model AIROSWEB.Models.LayoutViewModel
@{
    var bolgelerIcerik = Model.Icerikler.FirstOrDefault(x => x.BolumAdi == "BolgelerSayfasi");
    ViewBag.Title = bolgelerIcerik?.Baslik ?? "Hizmet Verdiğimiz Yerler | Bursa Teknik Servis";
    ViewBag.Description = bolgelerIcerik?.AltBaslik ?? "Bursa genelinde profesyonel teknik servis hizmeti verdiğimiz tüm ilçe ve bölgeler.";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ayar = Model.Ayarlar;
}

<!-- JSON-LD Structured Data for Local SEO -->
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "CollectionPage",
  "name": "@(bolgelerIcerik?.Baslik ?? "Hizmet Verdiğimiz Yerler")",
  "description": "@(bolgelerIcerik?.AltBaslik ?? "Bursa genelinde profesyonel teknik servis hizmeti verdiğimiz tüm ilçe ve bölgeler.")",
  "url": "@Request.Url.AbsoluteUri",
  "breadcrumb": {
    "@@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@@type": "ListItem",
        "position": 1,
        "name": "Anasayfa",
        "item": "@(Request.Url.GetLeftPart(UriPartial.Authority))"
      },
      {
        "@@type": "ListItem",
        "position": 2,
        "name": "@(bolgelerIcerik?.Baslik ?? "Hizmet Verdiğimiz Yerler")",
        "item": "@Request.Url.AbsoluteUri"
      }
    ]
  }
}
</script>

<!-- Page Header -->
<section class="page-header py-5 bg-dark text-white text-center position-relative overflow-hidden">
    <div class="header-bg-overlay" style="position: absolute; top:0; left:0; width:100%; height:100%; background: url('/Content/Images/hero-bg.jpg'); background-size: cover; background-position: center; opacity: 0.2; z-index: 1;"></div>
    <div class="container position-relative animate__animated animate__fadeInDown" style="z-index: 2;">
        <h1 class="display-4 fw-bold">@(bolgelerIcerik?.Baslik ?? "Hizmet Verdiğimiz Yerler")</h1>
        <p class="lead">@(bolgelerIcerik?.AltBaslik ?? "Bursa'nın her noktasına 7/24 kesintisiz teknik servis hizmeti sunuyoruz.")</p>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-white">Anasayfa</a></li>
                <li class="breadcrumb-item active text-white-50" aria-current="page">@(bolgelerIcerik?.Baslik ?? "Hizmet Verdiğimiz Yerler")</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Content Section -->
<section class="section-padding py-5 bg-light">
    <div class="container">
        
        <!-- Search & Filter -->
        <div class="row justify-content-center mb-5">
            <div class="col-md-8 col-lg-6">
                <div class="search-box position-relative shadow-sm rounded-pill bg-white p-2">
                    <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" id="regionSearch" class="form-control form-control-lg border-0 ps-5 rounded-pill" placeholder="İlçe veya semt adı arayın...">
                </div>
            </div>
        </div>

        <div class="row g-4" id="regionsContainer">
            @if (Model.HizmetBolgeleri != null && Model.HizmetBolgeleri.Any())
            {
                foreach (var bolge in Model.HizmetBolgeleri)
                {
                    <div class="col-lg-3 col-md-4 col-6 region-item">
                        <a href="@Url.Action("BolgeHizmet", "Home", new { slug = (bolge.Slug ?? AIROSWEB.Helpers.SeoHelper.ToSeoUrl(bolge.BolgeAdi)) })" class="text-decoration-none">
                            <div class="card h-100 border-0 shadow-sm hover-elevate overflow-hidden region-card">
                                <div class="card-body text-center p-4">
                                    <div class="icon-box mb-3 mx-auto bg-light rounded-circle d-flex align-items-center justify-content-center text-primary" style="width: 60px; height: 60px;">
                                        <i class="fas fa-map-marked-alt fa-2x"></i>
                                    </div>
                                    <h5 class="card-title fw-bold text-dark mb-2 region-name">@bolge.BolgeAdi</h5>
                                    <p class="card-text text-muted small fw-normal">Teknik Servis Hizmeti</p>
                                    <span class="btn btn-outline-primary btn-sm rounded-pill px-3 mt-2">İncele <i class="fas fa-arrow-right ms-1"></i></span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <!-- Fallback Data -->
                var fallbacks = new List<string> { "Nilüfer", "Osmangazi", "Yıldırım", "Mudanya", "Gürsu", "Kestel", "Gemlik", "İnegöl" };
                foreach (var f in fallbacks)
                {
                    <div class="col-lg-3 col-md-4 col-6 region-item">
                        <a href="/Bursa-Teknik-Servis/@AIROSWEB.Helpers.SeoHelper.ToSeoUrl(f)" class="text-decoration-none">
                            <div class="card h-100 border-0 shadow-sm hover-elevate overflow-hidden region-card">
                                <div class="card-body text-center p-4">
                                    <div class="icon-box mb-3 mx-auto bg-light rounded-circle d-flex align-items-center justify-content-center text-primary" style="width: 60px; height: 60px;">
                                        <i class="fas fa-map-marker-alt fa-2x"></i>
                                    </div>
                                    <h5 class="card-title fw-bold text-dark mb-2 region-name">@f</h5>
                                    <p class="card-text text-muted small fw-normal">Teknik Servis Bölgesi</p>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>

        <div id="noResults" class="text-center py-5 d-none">
            <div class="opacity-50 mb-3">
                <i class="fas fa-search fa-3x"></i>
            </div>
            <h4 class="fw-bold text-muted">Sonuç Bulunamadı</h4>
            <p class="text-muted">Aradığınız bölge için sonuç bulunamadı. Lütfen tekrar deneyin veya bizimle iletişime geçin.</p>
        </div>

    </div>
</section>

<!-- Map & CTA Section -->
<section class="section-padding bg-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="map-container rounded-4 overflow-hidden shadow-lg h-100" style="min-height: 400px;">
                    <!-- Bursa Map Embed (AIROS Specific) -->
                    @if (!string.IsNullOrEmpty(ayar?.HaritaEmbed)) {
                        <iframe src="@ayar.HaritaEmbed" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                    } else {
                        <iframe src="https://maps.google.com/maps?q=AIROS%20Teknik%20Servis%20Bursa&t=&z=13&ie=UTF8&iwloc=&output=embed" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    }
                </div>
            </div>
            <div class="col-lg-6">
                <div class="ps-lg-4">
                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill mb-3 fw-bold">7/24 HIZLI SERVİS</span>
                    <h2 class="fw-bold display-5 mb-4">Size En Yakın <span class="text-primary">Teknik Ekip</span> Bir Telefon Uzağınızda</h2>
                    <p class="lead text-muted mb-4">
                        Bursa'nın tüm ilçelerine yayılmış gezici servis araçlarımızla, çağrınızdan hemen sonra en kısa sürede adresinize ulaşıyoruz.
                    </p>
                    
                    <ul class="list-unstyled mb-5">
                        <li class="mb-3 d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3 fs-4"></i>
                            <span class="fs-5">30 Dakika içinde geri dönüş</span>
                        </li>
                        <li class="mb-3 d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3 fs-4"></i>
                            <span class="fs-5">Orijinal yedek parça garantisi</span>
                        </li>
                        <li class="mb-3 d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3 fs-4"></i>
                            <span class="fs-5">Kredi kartı ile ödeme imkanı</span>
                        </li>
                    </ul>

                    <div class="d-flex flex-wrap gap-3">
                        <a href="tel:@(ayar?.Telefon?.Replace(" ", "") ?? "05010022516")" class="btn btn-primary btn-lg rounded-pill px-5 shadow fw-bold">
                            <i class="fas fa-phone-alt me-2"></i> @(ayar?.Telefon ?? "0 501 002 25 16")
                        </a>
                        <a href="https://wa.me/@(ayar?.WhatsApp?.ToWhatsAppNumber())" class="btn btn-outline-success btn-lg rounded-pill px-5 fw-bold" target="_blank">
                            <i class="fab fa-whatsapp me-2"></i> WhatsApp
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hover-elevate {
        transition: all 0.3s ease;
    }
    .hover-elevate:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    }
    .region-card .icon-box {
        transition: all 0.3s ease;
    }
    .hover-elevate:hover .icon-box {
        background-color: #0d6efd !important;
        color: white !important;
    }
    .page-header { background: #212529; }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const searchInput = document.getElementById('regionSearch');
        const regionItems = document.querySelectorAll('.region-item');
        const noResults = document.getElementById('noResults');

        searchInput.addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            let hasResults = false;

            regionItems.forEach(item => {
                const name = item.querySelector('.region-name').textContent.toLowerCase();
                if (name.includes(filter)) {
                    item.classList.remove('d-none');
                    hasResults = true;
                } else {
                    item.classList.add('d-none');
                }
            });

            if (hasResults) {
                noResults.classList.add('d-none');
            } else {
                noResults.classList.remove('d-none');
            }
        });
    });
</script>
